# Set to "true" to serve generated fake appointments instead of calling
# Microsoft Graph. Useful for developing/testing the kiosk display before
# Azure AD access is set up. Leave unset/false in production.
USE_MOCK_DATA=false

# Azure AD app registration (client credentials flow)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# The shared mailbox/calendar to read appointments from
# (the user principal name or mailbox address, e.g. techboard@yourcompany.com)
CALENDAR_MAILBOX=

# How many minutes ahead to fetch appointments for the display. The kiosk
# board itself only shows the near-term ones by default (a client-side
# "Show future appointments" toggle in Settings reveals the rest of this
# window on demand). Default is 7 days.
LOOKAHEAD_MINUTES=10080

# How many minutes into the past to also fetch, so recently-ended
# appointments still show up (and can be flagged "past-due") before they
# age out of the live board and get archived to appointments-archive.csv.
# Default is 24 hours.
LOOKBACK_MINUTES=1440

# How often the server polls Microsoft Graph, in seconds
POLL_INTERVAL_SECONDS=60

# Port the local web server listens on
PORT=3000
